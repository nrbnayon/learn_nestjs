NODE_ENV=development
PORT=3001
APP_NAME=NestJS Chat Backend
APP_BASE_URL=http://localhost:3001
APP_HOST=127.0.0.1
API_PREFIX=api/v1

DATABASE_URL=postgresql://postgres:1234@localhost:5432/nestjs_chat_db?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=1234
DB_NAME=nestjs_chat_db

JWT_SECRET=replace_with_a_long_random_secret_key_32_chars_min
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=replace_with_a_second_long_random_secret_key
JWT_REFRESH_EXPIRES_IN=30d

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM="NestJS Chat" <noreply@nestjs-chat.com>
MAIL_SECURE=false

STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

CORS_ORIGINS=http://localhost:3000

# OAuth - Google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

THROTTLE_TTL=60
THROTTLE_LIMIT=100
