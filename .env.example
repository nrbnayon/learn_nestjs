# ========================
# Application
# ========================
NODE_ENV=development
PORT=3000
APP_NAME=NestJS Chat Backend
API_PREFIX=api/v1

# ========================
# Database (PostgreSQL)
# ========================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nestjs_chat_db?schema=public"
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=nestjs_chat_db

# ========================
# JWT
# ========================
JWT_SECRET=change_this_in_production_min_32_chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_REFRESH_EXPIRES_IN=30d

# ========================
# Redis
# ========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ========================
# Mail (SMTP)
# ========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM='"NestJS Chat" <noreply@nestjs-chat.com>'
MAIL_SECURE=false

# ========================
# Storage
# ========================
STORAGE_DRIVER=local
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# ========================
# BullMQ Queue
# ========================
QUEUE_REDIS_HOST=localhost
QUEUE_REDIS_PORT=6379
QUEUE_REDIS_PASSWORD=

# ========================
# CORS
# ========================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================
# Rate Limiting
# ========================
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ========================
# Socket.IO
# ========================
SOCKET_CORS_ORIGIN=http://localhost:5173
