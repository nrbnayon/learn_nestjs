    {
      "name": "Realtime Socket.IO",
      "description": "Use these requests in Postman as Socket.IO tabs. Connect with the Authorization header set to Bearer {{accessToken}}. The app uses the /chat namespace for messaging and /presence for online/offline tracking plus heartbeat refreshes.",
      "item": [
        {
          "name": "Connect to /chat",
          "description": "Open this as a Socket.IO request. Use it for room joins, send-message events, typing, and chat delivery on the /chat namespace.",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "ws://127.0.0.1:3001/chat",
              "protocol": "ws",
              "host": [
                "127.0.0.1"
              ],
              "port": "3001",
              "path": [
                "chat"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Connect to /presence",
          "description": "Open this as a Socket.IO request. Use it to receive user:online, user:offline, and presence:update events. Emit presence:heartbeat every {{presenceHeartbeatMs}} milliseconds.",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "ws://127.0.0.1:3001/presence",
              "protocol": "ws",
              "host": [
                "127.0.0.1"
              ],
              "port": "3001",
              "path": [
                "presence"
              ]
            }
          },
          "response": []
        }
      ]
    },
